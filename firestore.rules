rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Access config — any authenticated user can read (to check if allowed),
    // only admins can write (checked in app logic, Firestore checks auth)
    match /settings/access {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email in resource.data.admins;
      // Allow create if doc doesn't exist yet (first admin setup)
      allow create: if request.auth != null;
    }

    // Image search index — any authenticated user can read/write
    match /imageIndex/{fileId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
